#!/usr/bin/env bash
set -euo pipefail

PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
NOW=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

if [[ -f "$PROJECT_DIR/.env" ]]; then
    set -a
    source "$PROJECT_DIR/.env"
    set +a
fi

RED='\033[0;31m'
YELLOW='\033[0;33m'
NC='\033[0m'

log()  { echo -e "$@" >&2; }
warn() { echo -e "${YELLOW}WARN:${NC} $*" >&2; }
err()  { echo -e "${RED}ERROR:${NC} $*" >&2; }

# ---- 1. Rust (cargo update --dry-run --verbose) ----

log "==> Checking Rust dependencies..."
rust_json='['
rust_first=true
while IFS= read -r line; do
    if echo "$line" | grep -qE '^\s+Unchanged\s'; then
        name=$(echo "$line" | sed -n 's/^\s*Unchanged \([^ ]*\) .*/\1/p')
        current=$(echo "$line" | sed -n 's/.* v\([^ ]*\) (.*/\1/p')
        latest=$(echo "$line" | sed -n 's/.*available: v\([^)]*\).*/\1/p')
        kind="unchanged"
    elif echo "$line" | grep -qE '^\s+Updating\s'; then
        name=$(echo "$line" | sed -n 's/^\s*Updating \([^ ]*\) .*/\1/p')
        current=$(echo "$line" | sed -n 's/.* v\([^ ]*\) ->.*/\1/p')
        latest=$(echo "$line" | sed -n 's/.*-> v\([^)]*\).*/\1/p')
        kind="updating"
    else
        continue
    fi
    if [[ -n "$name" && -n "$current" && -n "$latest" ]]; then
        $rust_first || rust_json+=','
        rust_first=false
        rust_json+="{\"name\":\"$name\",\"current\":\"$current\",\"latest\":\"$latest\",\"kind\":\"$kind\"}"
    fi
done < <(cd "$PROJECT_DIR" && cargo update --dry-run --verbose 2>&1)
rust_json+=']'

# ---- 2. Deno ----

log "==> Checking Deno dependencies..."
deno_raw=$(cd "$PROJECT_DIR/e2e-tests" && deno outdated --json 2>/dev/null) || true
if [[ -z "$deno_raw" ]]; then
    deno_raw='[]'
fi
if ! echo "$deno_raw" | grep -q '^\[{' 2>/dev/null && ! echo "$deno_raw" | grep -q '^{' 2>/dev/null; then
    deno_raw='[]'
fi

# ---- 3. Mise ----

log "==> Checking mise tools..."
mise_raw=$(cd "$PROJECT_DIR" && mise outdated --json 2>/dev/null) || true
if [[ -z "$mise_raw" || "$mise_raw" == "{}" ]]; then
    mise_raw='[]'
fi

# ---- 4. GitHub Actions ----

log "==> Checking GitHub Actions..."

gh_json='['
gh_first=true

while IFS= read -r action_ref; do
    [[ -z "$action_ref" ]] && continue

    owner_repo="${action_ref%@*}"
    current_ver="${action_ref#*@}"

    latest_tag=$(gh api "repos/$owner_repo/releases/latest" --jq '.tag_name' 2>/dev/null) || true

    if [[ -z "$latest_tag" || "$latest_tag" == "null" ]]; then
        warn "Could not check $owner_repo (API call failed, no releases, or unauthenticated)"
        continue
    fi

    if [[ "$latest_tag" == "$current_ver" ]]; then
        continue
    fi

    if [[ "$latest_tag" == "$current_ver".* ]]; then
        continue
    fi

    files=$(grep -rl "uses:[[:space:]]*${action_ref}" "$PROJECT_DIR/.github/" 2>/dev/null \
        | sed "s|$PROJECT_DIR/||g" \
        | paste -sd ',' -)

    $gh_first || gh_json+=','
    gh_first=false
    gh_json+="{\"action\":\"$owner_repo\",\"current\":\"$current_ver\",\"latest\":\"$latest_tag\",\"files\":\"$files\"}"
done < <(
    grep -rh 'uses:' "$PROJECT_DIR/.github/workflows/" "$PROJECT_DIR/.github/actions/" 2>/dev/null \
        | grep -v 'uses:[[:space:]]*\./' \
        | sed -n 's/.*uses:[[:space:]]*\([^@[:space:]]\+@[^[:space:]#]\+[^[:space:]]*\).*/\1/p' \
        | sort -u
)
gh_json+=']'

# ---- 5. Docker ----

log "==> Checking Docker base images..."

docker_json='['
docker_first=true
while IFS= read -r dockerfile; do
    rel_path="${dockerfile#$PROJECT_DIR/}"
    while IFS= read -r from_line; do
        image=$(echo "$from_line" | sed -n 's/FROM[[:space:]]\+\([^[:space:]]\+\(:[^[:space:]]\+\)\?\).*/\1/p')
        [[ -z "$image" ]] && continue
        $docker_first || docker_json+=','
        docker_first=false
        docker_json+="{\"image\":\"$image\",\"file\":\"$rel_path\",\"note\":\"Docker base images must be verified manually (no automated registry check). Pull the image and compare digests.\"}"
    done < <(grep '^FROM ' "$dockerfile" 2>/dev/null || true)
done < <(find "$PROJECT_DIR" -name 'Dockerfile' -type f 2>/dev/null || true)
docker_json+=']'

# ---- Output ----

cat <<EOF
{
  "project": "cfgsync",
  "generated_at": "$NOW",
  "outdated": {
    "rust": $rust_json,
    "deno": $deno_raw,
    "mise": $mise_raw,
    "github_actions": $gh_json,
    "docker": $docker_json
  }
}
EOF
